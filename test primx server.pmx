# ========== Primix Server v0.4 ==========

start run/server
log on
debug on
cache on
queue on
timeout 30
env app_name = "Primix Demo"
/add t8t mixed

counter = 0
server_name = "Alpha"

# ---- Периодические задачи ----
every 5 min do
    print "Server alive"

every 30 sec do
    status

# ---- GET маршруты ----
go request / then
    respond "Welcome to " + server_name

go request /hello then
    respond "Hello, World!"

go request /api/users then
    respond json {"name": "Ivan", "age": 13}

go request /api/data then
    respond msgpack {"status": "ok"}

go request /count then
    counter = counter + 1
    respond "Total requests: " + counter

# ---- POST маршруты ----
go fields /save then
    store on/ data
    respond "Saved!"

go fields /upload then
    store on/ file
    respond "Uploaded!"

# ---- Логика ----
go request /check then
    if counter > 10 then
        respond "High load"
    else
        respond "Normal load"

# ---- Межсерверная связь ----
go request /sync then
    throw to/$key "sync_data"
    respond "Synced"

# ---- Безопасность ----
go request /block_enemy then
    block key bad_key
    respond "Blocked"

# ---- Служебные ----
go request /health then
    respond "OK"

go request /status then
    status

go request /clear_cache then
    clear cache
    respond "Cache cleared"

go request /save_state then
    save state
    respond "State saved"
